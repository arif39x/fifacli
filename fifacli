build_schedule() {
    declare -Ag G
    G["A"]="Mexico|Korea Republic|Czechia|South Africa"
    G["B"]="Canada|Bosnia and Herzegovina|Qatar|Switzerland"
    G["C"]="Brazil|Haiti|Scotland|Morocco"
    G["D"]="USA|Paraguay|Australia|Turkiye"
    G["E"]="Germany|Cote dIvoire|Ecuador|Curacao"
    G["F"]="Netherlands|Sweden|Tunisia|Japan"
    G["G"]="Belgium|Egypt|Iran|New Zealand"
    G["H"]="Spain|Cape Verde|Saudi Arabia|Uruguay"
    G["I"]="France|Senegal|Iraq|Norway"
    G["J"]="Argentina|Algeria|Austria|Jordan"
    G["K"]="Portugal|Congo DR|Uzbekistan|Colombia"
    G["L"]="England|Croatia|Ghana|Panama"

    local md1_dates=("2026-06-11" "2026-06-12" "2026-06-12" "2026-06-13" "2026-06-13" "2026-06-14" "2026-06-14" "2026-06-15" "2026-06-15" "2026-06-16" "2026-06-16" "2026-06-17")
    local md2_dates=("2026-06-18" "2026-06-18" "2026-06-19" "2026-06-19" "2026-06-20" "2026-06-20" "2026-06-21" "2026-06-21" "2026-06-22" "2026-06-22" "2026-06-23" "2026-06-23")
    local md3_dates=("2026-06-25" "2026-06-25" "2026-06-26" "2026-06-26" "2026-06-26" "2026-06-26" "2026-06-27" "2026-06-27" "2026-06-27" "2026-06-27" "2026-06-27" "2026-06-27")
    local times=("01:00" "23:00")
    local vpool=("Mexico City" "Guadalajara" "Toronto" "Vancouver" "Los Angeles" "San Francisco" "New Jersey" "Boston" "Dallas" "Houston" "Atlanta" "Miami" "Seattle" "Kansas City" "Philadelphia" "Monterrey")

    local idx=0 group schedule=()
    for group in A B C D E F G H I J K L; do
        IFS='|' read -r t1 t2 t3 t4 <<< "${G[$group]}"
        local d1="${md1_dates[$idx]}" d2="${md2_dates[$idx]}" d3="${md3_dates[$idx]}"
        local v1="${vpool[idx * 2 % 16]}" v2="${vpool[(idx * 2 + 1) % 16]}"
        local v3="${vpool[(idx * 2 + 4) % 16]}" v4="${vpool[(idx * 2 + 5) % 16]}"
        schedule+=("$d1 ${times[0]}|$t1 vs $t4|Group $group|${v1} Stadium")
        schedule+=("$d1 ${times[1]}|$t2 vs $t3|Group $group|${v2} Stadium")
        schedule+=("$d2 ${times[0]}|$t1 vs $t3|Group $group|${v3} Stadium")
        schedule+=("$d2 ${times[1]}|$t4 vs $t2|Group $group|${v4} Stadium")
        schedule+=("$d3 ${times[0]}|$t1 vs $t2|Group $group|${v1} Stadium")
        schedule+=("$d3 ${times[1]}|$t4 vs $t3|Group $group|${v2} Stadium")
        idx=$((idx + 1))
    done

    local r32_dates=("2026-06-28" "2026-06-29" "2026-06-30" "2026-07-01" "2026-07-01" "2026-07-02" "2026-07-02" "2026-07-03")
    local r32_times=("23:00" "01:00")
    for i in $(seq 0 7); do
        schedule+=("${r32_dates[$i]} ${r32_times[0]}|Round of 32: Match $((i*2+1))|Round of 32|Stadium TBD")
        schedule+=("${r32_dates[$i]} ${r32_times[1]}|Round of 32: Match $((i*2+2))|Round of 32|Stadium TBD")
    done

    local r16_dates=("2026-07-04" "2026-07-05" "2026-07-06" "2026-07-07")
    for i in $(seq 0 3); do
        schedule+=("${r16_dates[$i]} ${r32_times[0]}|Round of 16: Match $((i*2+1))|Round of 16|Stadium TBD")
        schedule+=("${r16_dates[$i]} ${r32_times[1]}|Round of 16: Match $((i*2+2))|Round of 16|Stadium TBD")
    done

    schedule+=("2026-07-09 23:00|Quarterfinal 1|Quarterfinal|Stadium TBD")
    schedule+=("2026-07-10 23:00|Quarterfinal 2|Quarterfinal|Stadium TBD")
    schedule+=("2026-07-11 23:00|Quarterfinal 3|Quarterfinal|Stadium TBD")
    schedule+=("2026-07-12 23:00|Quarterfinal 4|Quarterfinal|Stadium TBD")
    schedule+=("2026-07-14 23:00|Semifinal 1|Semifinal|New Jersey Stadium")
    schedule+=("2026-07-15 23:00|Semifinal 2|Semifinal|Dallas Stadium")
    schedule+=("2026-07-18 21:00|Third Place Playoff|Third Place|Mexico City Stadium")
    schedule+=("2026-07-19 22:00|World Cup Final|Final|New Jersey Stadium")

    printf '%s\n' "${schedule[@]}"
}

SCHEDULE=()
while IFS= read -r line; do
    SCHEDULE+=("$line")
done < <(build_schedule)

date_to_epoch() {
    local dt="$1"
    local epoch
    epoch=$(date -u -d "$dt" +%s 2>/dev/null) || epoch=$(date -u -j -f "%Y-%m-%d %H:%M" "$dt" +%s 2>/dev/null) || return 1
    echo "$epoch"
}

now_epoch() {
    date -u +%s 2>/dev/null || date +%s
}

find_matches() {
    local now_e match_e dt match stage venue line live_list=() upcoming_list=()
    now_e=$(now_epoch)

    for line in "${SCHEDULE[@]}"; do
        dt="${line%%|*}"
        match_e=$(date_to_epoch "$dt") || continue

        IFS='|' read -r _ match stage venue <<< "$line"

        if [[ $now_e -ge $match_e && $now_e -le $((match_e + 8100)) ]]; then
            local elapsed=$(( (now_e - match_e) / 60 ))
            live_list+=("$elapsed|$match|$stage|$venue|$dt")
        elif [[ $now_e -lt $match_e ]]; then
            upcoming_list+=("$match_e|$match|$stage|$venue|$dt")
        fi
    done

    if [[ ${#live_list[@]} -gt 0 ]]; then
        printf 'live\n'
        printf '%s\n' "${live_list[@]}"
        return
    fi

    if [[ ${#upcoming_list[@]} -gt 0 ]]; then
        local sorted upcoming_line
        sorted=$(printf '%s\n' "${upcoming_list[@]}" | sort -n -t'|' -k1 | head -3)
        printf 'upcoming\n'
        echo "$sorted"
    fi
}

show_match_status() {
    local result match_info
    result=$(find_matches)
    local status
    status=$(echo "$result" | head -1)
    match_info=$(echo "$result" | tail -n +2)

    if [[ "$status" == "live" ]]; then
        echo "  >>> LIVE NOW <<<"
        echo "$match_info" | while IFS='|' read -r elapsed match stage venue dt; do
            printf "  %-35s %s ago | %s | %s\n" "$match" "${elapsed}m" "$stage" "$venue"
        done
    elif [[ "$status" == "upcoming" ]]; then
        echo "  Upcoming Matches:"
        echo "$match_info" | while IFS='|' read -r epoch match stage venue dt; do
            local display
            display=$(date -u -d "@$epoch" +"%a %b %d %H:%M UTC" 2>/dev/null || \
                     date -u -r "$epoch" +"%a %b %d %H:%M UTC" 2>/dev/null)
            printf "  %-35s %s | %s\n" "$match" "$display" "$venue"
        done
    fi
}

declare -A CHANNELS
CHANNELS["UK BBC One (English)"]="https://www.bbc.co.uk/iplayer/live/bbcone"
CHANNELS["UK ITV1 (English)"]="https://www.itv.com/watch/live/itv1"
CHANNELS["Brazil CazeTV (Portuguese)"]="https://www.youtube.com/@CazeTV/live"
CHANNELS["France BFM (French)"]="https://www.bfmtv.com/en-direct/"
CHANNELS["Germany ZDF (German)"]="https://www.zdf.de/live-tv/zdf"
CHANNELS["Spain RTVE (Spanish)"]="https://www.rtve.es/play/en-directo/la-1/"

play_ytdlp() {
    local url="$1"
    local quality="$2"
    local extra_args=()

    if [[ -n "${HTTP_PROXY:-}" ]]; then
        extra_args+=(--proxy "${HTTP_PROXY}")
    fi
    if [[ -n "${COOKIES_FILE:-}" && -f "${COOKIES_FILE}" ]]; then
        extra_args+=(--cookies "${COOKIES_FILE}")
    fi
    if [[ "$url" == *bbc.co.uk* ]] && [[ -n "${BBC_EMAIL:-}" ]]; then
        extra_args+=(--username "${BBC_EMAIL}" --password "${BBC_PASS:-}")
    fi
    if [[ "$url" == *itv.com* ]] && [[ -n "${ITVX_EMAIL:-}" ]]; then
        extra_args+=(--username "${ITVX_EMAIL}" --password "${ITVX_PASS:-}")
    fi

    local fmt_args=()
    [[ "$quality" != "best" ]] && fmt_args=(-f "$quality")
    yt-dlp "${fmt_args[@]}" -o - "$url" "${extra_args[@]}" 2>/tmp/fifacli_ytdlp_err | mpv --no-terminal --geometry=50%:50% --autofit=800x450 -
    local ret=${PIPESTATUS[0]}

    if [[ $ret -ne 0 && -f /tmp/fifacli_ytdlp_err ]]; then
        local err
        err=$(</tmp/fifacli_ytdlp_err)
        if [[ "$err" == *"not currently live"* ]]; then
            echo "Channel is not currently live."
        elif [[ "$err" == *"Unable to extract"* || "$err" == *"Failed to extract"* ]]; then
            echo "Stream extraction failed (upstream issue)."
        elif [[ "$err" == *"HTTP Error 404"* ]]; then
            echo "URL not found — the stream URL may have changed."
        elif [[ "$err" == *"requires an account"* || "$err" == *"Login required"* ]]; then
            echo "Login required — set credentials in config."
        elif [[ "$err" == *"403"* || "$err" == *"Geoblock"* || "$err" == *"geo"* ]]; then
            echo "Geo-blocked — this channel is not available in your region."
        elif [[ "$err" == *"Downloading 0 items"* || "$err" == *"0 items"* ]]; then
            echo "No live stream found on this channel."
        fi
        rm -f /tmp/fifacli_ytdlp_err
    fi
    return $ret
}

play_streamlink() {
    local url="$1"
    local quality="$2"
    local player="mpv --no-terminal --geometry=50%:50% --autofit=800x450"
    local args=(streamlink "$url" "$quality" --player "$player")

    if [[ "$url" == *bbc.co.uk* ]] && [[ -n "${BBC_EMAIL:-}" ]]; then
        args+=(--bbciplayer-username "${BBC_EMAIL}" --bbciplayer-password "${BBC_PASS:-}")
    fi
    if [[ -n "${HTTP_PROXY:-}" ]]; then
        args+=(--http-proxy "${HTTP_PROXY}")
    fi

    "${args[@]}" 2>/tmp/fifacli_slink_err
    local ret=$?
    if [[ $ret -ne 0 && -f /tmp/fifacli_slink_err ]]; then
        local err
        err=$(</tmp/fifacli_slink_err)
        if [[ "$err" == *"requires an account"* ]]; then
            echo "Login required — set credentials in config."
        elif [[ "$err" == *"No playable streams"* ]]; then
            echo "No stream available — channel may be offline."
        fi
        rm -f /tmp/fifacli_slink_err
    fi
    return $ret
}

play_url() {
    local url="$1"
    local quality="${2:-${QUALITY:-best}}"
    local channel_type=""

    if [[ "$url" == *youtube.com* || "$url" == *youtu.be* ]]; then
        channel_type="YouTube"
    elif [[ "$url" == *bbc.co* ]]; then
        channel_type="BBC"
    elif [[ "$url" == *itv.com* ]]; then
        channel_type="ITV"
    fi

    if command -v yt-dlp &>/dev/null; then
        play_ytdlp "$url" "$quality" && return 0
        if [[ "$channel_type" == "YouTube" ]]; then
            return 1
        fi
        echo "Trying streamlink..."
    fi

    if command -v streamlink &>/dev/null; then
        play_streamlink "$url" "$quality" && return 0
    fi

    return 1
}

lang_picker() {
    local langs=(
        "English (BBC One)"
        "English (ITV1)"
        "Português (CazeTV)"
        "Français (BFM)"
        "Deutsch (ZDF)"
        "Español (RTVE)"
        "Exit"
    )
    printf '%s\n' "${langs[@]}" | fzf \
        --prompt="Select Language " \
        --border=rounded \
        --color="$FZF_COLORS" \
        --height=10
}

main() {
    check_deps
    init_config

    while true; do
        header
        show_match_status
        echo

        local pick
        pick=$(lang_picker) || exit 0
        [[ -z "$pick" ]] && exit 0

        case "$pick" in
            "Exit") exit 0 ;;
        esac

        local channel url
        case "$pick" in
            "English (BBC One)") channel="UK BBC One (English)" ;;
            "English (ITV1)")    channel="UK ITV1 (English)" ;;
            "Português (CazeTV)") channel="Brazil CazeTV (Portuguese)" ;;
            "Français (BFM)")    channel="France BFM (French)" ;;
            "Deutsch (ZDF)")     channel="Germany ZDF (German)" ;;
            "Español (RTVE)")    channel="Spain RTVE (Spanish)" ;;
        esac

        url="${CHANNELS[$channel]}"
        echo "Loading: $pick"
        play_url "$url"
        echo
        read -rp "Press Enter..."
    done
}

main "$@"
