check_deps() {
    local missing=()
    for cmd in fzf mpv yt-dlp; do
        if ! command -v "$cmd" &>/dev/null; then
            missing+=("$cmd")
        fi
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        echo "Missing required dependencies: ${missing[*]}" >&2
        echo "Install with: sudo pacman -S ${missing[*]}" >&2
        exit 1
    fi
    if ! command -v streamlink &>/dev/null; then
        echo "Note: streamlink not found (optional fallback)" >&2
    fi
}

init_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        mkdir -p "$CONFIG_DIR"
        cat > "$CONFIG_FILE" <<-EOF
QUALITY=best
BBC_EMAIL=
BBC_PASS=
ITVX_EMAIL=
ITVX_PASS=
HTTP_PROXY=
COOKIES_FILE=
EOF
        echo "Created default config at $CONFIG_FILE"
    fi
    source "$CONFIG_FILE"
}

