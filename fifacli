#!/usr/bin/env bash
set -u

CONFIG_DIR="${HOME}/.config/wc-cli"
CONFIG_FILE="${CONFIG_DIR}/config"

FZF_COLORS='fg:#d4d4d4,bg:#1e1e2e,hl:#89b4fa,fg+:#cdd6f4,bg+:#313244,gutter:#1e1e2e,hl+:#89b4fa,info:#f5c2e7,prompt:#a6e3a1,pointer:#f38ba8,marker:#f38ba8,spinner:#f5c2e7,header:#89b4fa'

check_deps() {
    local missing=()
    for cmd in fzf mpv yt-dlp; do
        if ! command -v "$cmd" &>/dev/null; then
            missing+=("$cmd")
        fi
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        echo "Missing required dependencies: ${missing[*]}" >&2
        echo "Install with: sudo pacman -S ${missing[*]}" >&2
        exit 1
    fi
    if ! command -v streamlink &>/dev/null; then
        echo "Note: streamlink not found (optional fallback)" >&2
    fi
}

init_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        mkdir -p "$CONFIG_DIR"
        cat > "$CONFIG_FILE" <<-EOF
QUALITY=best
BBC_EMAIL=
BBC_PASS=
ITVX_EMAIL=
ITVX_PASS=
HTTP_PROXY=
COOKIES_FILE=
EOF
        echo "Created default config at $CONFIG_FILE"
    fi
    source "$CONFIG_FILE"
}

