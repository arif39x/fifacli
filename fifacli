#!/usr/bin/env bash
set -u

STREAMS=(
    "https://live05.msdht.app/live/14830711.m3u8"
    "https://5cup.s3.us-east-2.amazonaws.com/max1/master.m3u8"
    "https://s3.us-east-1.amazonaws.com/cdnh120/hls/0/stream.m3u8"
    "https://d2zihajmogu5jn.cloudfront.net/elephantsdream/hls/manifest5/index.m3u8"
)

UA="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"

pick_player() {
    if command -v mpv &>/dev/null; then
        echo "mpv"
    elif command -v ffplay &>/dev/null; then
        echo "ffplay"
    elif command -v cvlc &>/dev/null; then
        echo "cvlc"
    else
        echo ""
    fi
}

AUDIO_DEVICE="pipewire/alsa_output.pci-0000_00_1f.3.analog-stereo"

play_mpv() {
    mpv --no-terminal --volume=100 --af=volume=20dB --cache=yes \
        --audio-device="$AUDIO_DEVICE" \
        --demuxer-max-bytes=150M \
        --timeout=20 --hls-segment-timeout=20 \
        --user-agent="$UA" "$1"
}

play_ffplay() {
    PULSE_SINK="alsa_output.pci-0000_00_1f.3.analog-stereo" \
    ffplay -loglevel warning -fflags nobuffer -flags low_delay -framedrop \
        -infbuf -analyzeduration 0 -probesize 32 -volume 100 \
        -af "volume=10.0" -user_agent "$UA" "$1"
}

play_cvlc() {
    PULSE_SINK="alsa_output.pci-0000_00_1f.3.analog-stereo" \
    cvlc --no-video-title-show --volume 512 --audio-filter=compressor "$1"
}

play_stream() {
    local url="$1" player
    player=$(pick_player)
    [[ -z "$player" ]] && { echo "No player found (install mpv, ffmpeg, or vlc)"; return 1; }
    case "$player" in
        mpv)   play_mpv "$url"   ;;
        ffplay) play_ffplay "$url" ;;
        cvlc)  play_cvlc "$url"  ;;
    esac
}

check_stream() {
    local code
    code=$(curl -sI --max-time 5 -o /dev/null -w "%{http_code}" -H "User-Agent: $UA" "$1" 2>/dev/null)
    [[ "$code" == "200" ]]
}

main() {
    for cmd in fzf curl; do
        if ! command -v "$cmd" &>/dev/null; then
            echo "Missing: $cmd. Install with: sudo pacman -S $cmd" >&2
            exit 1
        fi
    done

    if [[ "$(pick_player)" == "" ]]; then
        echo "No media player found. Install mpv, ffmpeg, or vlc" >&2
        exit 1
    fi

    local choice
    printf "\n"
    echo "______   __     ______   ______     ______     __         __    "
    echo "/\  ___\ /\ \   /\  ___\ /\  __ \   /\  ___\   /\ \       /\ \   "
    echo "\ \  __\ \ \ \  \ \  __\ \ \  __ \  \ \ \____  \ \ \____  \ \ \  "
    echo " \ \_\    \ \_\  \ \_\    \ \_\ \_\  \ \_____\  \ \_____\  \ \_\ "
    echo "  \/_/     \/_/   \/_/     \/_/\/_/   \/_____/   \/_____/   \/_/ "
    printf "\n"
    choice=$(printf "Start Stream\nScrape (auto-find)\nExit" | fzf \
        --prompt="Select " --border=rounded --height=8)

    [[ -z "$choice" || "$choice" == "Exit" ]] && exit 0

    if [[ "$choice" == "Scrape (auto-find)" ]]; then
        local sd="$(dirname "$0")/scrapers"
        local py="${sd}/venv/bin/python3" scr="${sd}/extract_stream.py"
        if [[ ! -f "$py" || ! -f "$scr" ]]; then
            echo "Scraper not found. Run setup from README." >&2
            exit 1
        fi
        echo "Searching for streams..."
        local result
        result=$("$py" "$scr" "https://www.goatsports.xyz/p/why-is-maradonas-goal-called-hand-of.html" --timeout 25 2>&1)
        if [[ "$result" == ERROR:* ]]; then
            echo "$result" >&2
            exit 1
        fi
        play_stream "$result"
        exit $?
    fi

    local tried=0
    for url in "${STREAMS[@]}"; do
        echo -n "Trying $(echo "$url" | sed 's|https://||;s|/.*||')... "
        if check_stream "$url"; then
            echo "alive"
            play_stream "$url" && exit 0
            tried=$((tried + 1))
        else
            echo "dead"
        fi
    done

    echo "All streams failed."
    exit 1
}

main "$@"
